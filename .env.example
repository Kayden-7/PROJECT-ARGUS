# PROJECT-ARGUS environment template.
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.
#
# FRONTEND DEVELOPERS: you do NOT need real Google/OpenAI keys to build the UI.
# Use the fake login (PROJECT_ARGUS / ARGUS_DEMO) — see SETUP_GOOGLE_OAUTH.md.
# These values are only needed to run the live backend with real Gmail/GPT.

# ── Google OAuth (from Google Cloud Console → Credentials → OAuth client) ──────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must EXACTLY match an Authorized redirect URI on the OAuth client:
GOOGLE_REDIRECT_URI=http://localhost:8081/oauth2callback
# The Gmail account ARGUS operates on (the demo mailbox):
ARGUS_GMAIL=your-demo-account@gmail.com

# ── Flask ─────────────────────────────────────────────────────────────────────
# Any long random string. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── OpenAI (Phase 9 GPT-4o agent) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
